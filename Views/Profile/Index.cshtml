@using SocialApp.Helpers
@model SocialApp.Models.ProfileViewModel
@{
    ViewData["Title"] = $"@{Model.User.username}";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8">
            <div class="card mb-4">
                <div class="card-body">
                    <div class="text-center">
                        <img src="@(Model.User.avatar_url ?? "/images/default-avatar.png")" 
                             class="rounded-circle mb-3" width="120" height="120" alt="avatar">
                        <h2>@Model.User.display_name</h2>
                        <p class="text-muted">@@@Model.User.username</p>
                        @if (!string.IsNullOrEmpty(Model.User.bio))
                        {
                            <p>@Model.User.bio</p>
                        }
                        <div class="d-flex justify-content-center gap-4">
                            <div><strong>@Model.PostCount</strong> posts</div>
                            <div><strong>@Model.LikeCount</strong> total likes</div>
                        </div>
                    </div>
                </div>
            </div>
            
            <h3>Posts</h3>
            @foreach (var post in Model.UserPosts)
            {
                <div class="card mb-3">
                    <div class="card-body">
                        <a href="/feed/post/@post.Post.post_id" class="text-decoration-none text-dark">
                            <p class="card-text">@Html.Raw(HashtagHelper.ConvertHashtagsToLinks(post.Post.content))</p>
                            
                            @if (post.Post.post_type != "text" && !string.IsNullOrEmpty(post.Post.media_url))
                            {
                                <div class="mt-2">
                                    @if (post.Post.post_type == "image")
                                    {
                                        <img src="@post.Post.media_url" class="img-fluid rounded" alt="@post.Post.alt_text">
                                    }
                                    else if (post.Post.post_type == "video")
                                    {
                                        <video controls class="w-100 rounded">
                                            <source src="@post.Post.media_url" type="video/mp4">
                                            Your browser does not support the video tag.
                                        </video>
                                    }
                                </div>
                            }
                        </a>
                        
                        @if (post.Event != null)
                        {
                            <div class="alert alert-info mt-2">
                                <strong>📅 Event:</strong> @post.Event.event_time.ToString("MMM dd, yyyy • h:mm tt")<br>
                                <strong>📍 Location:</strong> @post.Event.location
                            </div>
                        }
                        
                        <div class="mt-3">
                            <span class="me-3">❤️ @post.LikeCount</span>
                            <span class="me-3">💬 @post.CommentCount</span>
                            <span class="me-3">🔄 @post.ReribbCount</span>
                        </div>
                        
                        <small class="text-muted">@post.Post.created_at.ToString("MMM dd, yyyy")</small>
                    </div>
                </div>
            }
        </div>
        
        <div class="col-md-4">
            @await Html.PartialAsync("_TrendingTags", Model.TrendingTags)
        </div>
    </div>
</div>