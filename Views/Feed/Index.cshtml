@using SocialApp.Helpers
@model SocialApp.Models.FeedViewModel
@{
    ViewData["Title"] = "Feed";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8">
            <h2>Latest Posts</h2>
            
            @foreach (var post in Model.Posts)
            {
                <div class="card mb-3">
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-2">
                            <img src="@(post.User.avatar_url ?? "/images/default-avatar.png")" 
                                 class="rounded-circle me-2" width="40" height="40" alt="avatar">
                            <div>
                                <a href="/profile/@post.User.username" class="fw-bold text-decoration-none">
                                    @post.User.display_name
                                </a>
                                <small class="text-muted d-block">@@@post.User.username</small>
                            </div>
                            <small class="text-muted ms-auto">@post.Post.created_at.ToString("MMM dd, yyyy • h:mm tt")</small>
                        </div>
                        
                        <a href="/feed/post/@post.Post.post_id" class="text-decoration-none text-dark">
                            <p class="card-text">@Html.Raw(HashtagHelper.ConvertHashtagsToLinks(post.Post.content))</p>
                            
                            @if (post.Post.post_type != "text" && !string.IsNullOrEmpty(post.Post.media_url))
                            {
                                <div class="mt-2">
                                    @if (post.Post.post_type == "image")
                                    {
                                        <img src="@post.Post.media_url" class="img-fluid rounded" alt="@post.Post.alt_text">
                                    }
                                    else if (post.Post.post_type == "video")
                                    {
                                        <video controls class="w-100 rounded">
                                            <source src="@post.Post.media_url" type="video/mp4">
                                            Your browser does not support the video tag.
                                        </video>
                                    }
                                </div>
                            }
                        </a>
                        
                        @if (post.Event != null)
                        {
                            <div class="alert alert-info mt-2">
                                <strong>📅 Event:</strong> @post.Event.event_time.ToString("MMM dd, yyyy • h:mm tt")<br>
                                <strong>📍 Location:</strong> @post.Event.location<br>
                                @if (post.Event.host_org != null)
                                {
                                    <strong>🏢 Host:</strong> @post.Event.host_org<br>
                                }
                                <strong>👥 RSVP:</strong> @post.RsvpCount / @(post.Event.max_capacity?.ToString() ?? "∞")
                            </div>
                        }
                        
                        <div class="mt-3">
                            <span class="me-3">❤️ @post.LikeCount</span>
                            <span class="me-3">💬 @post.CommentCount</span>
                            <span class="me-3">🔄 @post.ReribbCount</span>
                            @if (post.Event != null)
                            {
                                <span>✅ @post.RsvpCount RSVP</span>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
        
        <div class="col-md-4">
            @await Html.PartialAsync("_TrendingTags", Model.TrendingTags)
        </div>
    </div>
</div>