@model List<SocialApp.Models.TrendingTag>

<div class="card">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0">🔥 Trending Ponds</h5>
        <a href="/ponds/trending" class="text-white text-decoration-none small">Все тренды →</a>
    </div>
    <div class="card-body">
        @if (Model != null && Model.Any())
        {
            <div class="list-group list-group-flush">
                @foreach (var tag in Model.Take(5))
                {
                    <a href="/ponds/posts/@tag.tag_name" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                        <span>
                            <span class="text-primary">#</span>@tag.tag_name
                        </span>
                        <span class="badge bg-secondary rounded-pill">@tag.recent_posts posts</span>
                    </a>
                }
            </div>
            @if (Model.Count > 5)
            {
                <div class="text-center mt-2">
                    <a href="/ponds/trending" class="btn btn-sm btn-outline-primary">Показать все @Model.Count тегов</a>
                </div>
            }
        }
        else
        {
            <p class="text-muted mb-0 text-center">Пока нет трендовых тегов</p>
        }
    </div>
</div>

<div class="card mt-3">
    <div class="card-header bg-light">
        <h5 class="mb-0">📊 Статистика тегов</h5>
    </div>
    <div class="card-body">
        <div class="d-flex justify-content-between mb-2">
            <span>Всего тегов:</span>
            <strong>@(ViewBag.TotalTagsCount ?? 0)</strong>
        </div>
        <div class="d-flex justify-content-between mb-2">
            <span>Активных тегов:</span>
            <strong>@(ViewBag.ActiveTagsCount ?? 0)</strong>
        </div>
        <hr>
        <a href="/ponds/all" class="btn btn-sm btn-outline-secondary w-100">
            <i class="bi bi-tags"></i> Все теги
        </a>
        <a href="/ponds/popular" class="btn btn-sm btn-outline-secondary w-100 mt-2">
            <i class="bi bi-star"></i> Популярные
        </a>
    </div>
</div>