@model List<SocialApp.Models.Tag>
@{
    ViewData["Title"] = ViewBag.Title ?? "All Ponds";
    var trendingTags = ViewBag.TrendingTags as List<SocialApp.Models.TrendingTag>;
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1>
                    <i class="bi bi-tags"></i> Все теги
                    <small class="text-muted fs-5">(@ViewBag.TotalTags тегов)</small>
                </h1>
                <form asp-action="Search" asp-controller="Ponds" method="post" class="d-flex">
                    <input type="text" name="searchTerm" class="form-control me-2" placeholder="Поиск тегов..." />
                    <button type="submit" class="btn btn-primary">🔍</button>
                </form>
            </div>

            <div class="card">
                <div class="card-body">
                    @foreach (var tag in Model)
                    {
                        <!-- ВАЖНО: ссылка на /ponds/posts/имя_тега -->
                        <a href="/ponds/posts/@tag.tag_name" class="btn btn-outline-secondary m-1">
                            #@tag.tag_name <span class="badge bg-secondary">@tag.usage_count</span>
                        </a>
                    }
                </div>
            </div>
        </div>
        
        <div class="col-md-4">
            @await Html.PartialAsync("_TrendingTags", trendingTags)
        </div>
    </div>
</div>