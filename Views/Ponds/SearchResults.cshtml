@using SocialApp.Helpers
@model List<SocialApp.Models.Tag>
@{
    ViewData["Title"] = $"Поиск: {ViewBag.SearchTerm}";
    var trendingTags = ViewBag.TrendingTags as List<SocialApp.Models.TrendingTag>;
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0">
                        🔍 Результаты поиска: "#@ViewBag.SearchTerm"
                    </h3>
                </div>
                <div class="card-body">
                    @if (Model != null && Model.Any())
                    {
                        <p class="text-muted">Найдено тегов: @Model.Count</p>
                        <div class="list-group">
                            @foreach (var tag in Model)
                            {
                                <a href="/ponds/posts/@tag.tag_name" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                    <div>
                                        <strong>#@tag.tag_name</strong>
                                    </div>
                                    <div>
                                        <span class="badge bg-secondary rounded-pill">@tag.usage_count использований</span>
                                    </div>
                                </a>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle"></i> Теги по запросу "#@ViewBag.SearchTerm" не найдены.
                        </div>
                        <a href="/ponds/all" class="btn btn-outline-primary">Показать все теги</a>
                    }
                </div>
            </div>
        </div>
        
        <div class="col-md-4">
            @await Html.PartialAsync("_TrendingTags", trendingTags)
        </div>
    </div>
</div>